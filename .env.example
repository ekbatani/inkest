# Copy to .env.local and fill in.

# Database (local libSQL for dev; switch to Turso remote for prod)
DATABASE_URL=file:./data/local.db
DATABASE_AUTH_TOKEN=

# Auth.js and the public URL used for metadata
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local filesystem attachment storage
ATTACHMENT_STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./storage
MAX_UPLOAD_SIZE_MB=20
ALLOWED_UPLOAD_TYPES=image/png,image/jpeg,image/webp,image/gif,image/svg+xml,application/pdf,application/epub+zip,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# AI (OpenAI-compatible). Leave provider API keys empty to exercise the unavailable-provider state.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENCODE_API_KEY=
OPENCODE_MODEL=
OPENCODE_BASE_URL=
OLLAMA_MODEL=
OLLAMA_BASE_URL=http://localhost:11434/v1

# Google Calendar OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Telegram notifications and webhook verification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Optional private S3-compatible attachment storage
# ATTACHMENT_STORAGE_DRIVER=minio
MINIO_ENDPOINT=
MINIO_BUCKET=
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
